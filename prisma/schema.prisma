// ============================================================

enum EntityFormationType {
  US_DELAWARE_C_CORP
  US_DELAWARE_LLC
  US_WYOMING_LLC
  US_NEVADA_C_CORP
  US_OTHER_STATE
  NZ_LIMITED
  AU_PROPRIETARY_LIMITED
  AU_PUBLIC_COMPANY
  UK_LIMITED
  UK_LLP
  SG_PRIVATE_LIMITED
  CA_FEDERAL_CORP
  CA_PROVINCIAL_CORP
  OTHER
}

enum EntityFormationStatus {
  DRAFT
  AWAITING_SIGNOFF
  FILING_SUBMITTED
  FILING_ACCEPTED
  AWAITING_EIN
  AWAITING_BANK
  COMPLETE
  REJECTED
  CANCELLED
}

model EntityFormation {
  id                   String                @id @default(cuid())
  firmId               String?
  firm                 Firm?                 @relation(fields: [firmId], references: [id])
  founderUserId        String?
  proposedName         String
  formationType        EntityFormationType
  jurisdiction         String                // ISO subcode where filed
  status               EntityFormationStatus  @default(DRAFT)
  // Authorised share / capital structure (C-Corp / Pty Ltd / Ltd)
  authorisedShares     Int?
