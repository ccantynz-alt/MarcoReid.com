generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ============================================================
// AUTH
// ============================================================

enum Role {
  USER
  ADMIN
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  emailVerifiedAt DateTime?
  name          String?
  passwordHash  String
  role          Role             @default(USER)
  firmName      String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  queries          OracleQuery[]
  feedback         OracleFeedback[]
  clients          Client[]
  matters          Matter[]
  documents        Document[]
  timeEntries      TimeEntry[]
  trustAccounts    TrustAccount[]
  voiceTranscripts VoiceTranscript[]

  // Marketplace
  professionalProfile Professional? @relation("ProfessionalProfile")
  citizenMatters      ProMatter[]   @relation("CitizenMatters")

  // Stripe — subscriptions
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique
  stripePriceId         String?
  subscriptionStatus    String?
  subscriptionPeriodEnd DateTime?

  // Stripe Connect — marketplace
  stripeConnectAccountId String?              @unique
  connectOnboarded       Boolean              @default(false)
  marketplacePayments    MarketplacePayment[] @relation("ProfessionalPayments")

  // Onboarding
  onboardedAt   DateTime?
  jurisdiction  String?
  practiceArea  String?

  // Consent audit trail — evidentiary record for ToS + platform acknowledgment.
  // Versioned so we can tell who accepted which wording. IP + user-agent
  // captured at signup for the same reason. See lib/consent.ts for the current
  // versions and the acknowledgment text.
  tosVersion         String?
  tosAcceptedAt      DateTime?
  platformAckVersion String?
  platformAckAt      DateTime?
  signupIp           String?
  signupUserAgent    String?
}

// ============================================================
// PRACTICE FOUNDATION — Clients, Matters, Documents, Billing
// ============================================================

enum MatterStatus {
  ACTIVE
  ON_HOLD
  CLOSED
}

enum DocumentKind {
  CONTRACT
  LETTER
  COURT_FILING
  EVIDENCE
  INVOICE
  RECEIPT
  OTHER
}

enum TrustTransactionType {
  DEPOSIT
  WITHDRAWAL
  FEE_DRAW
}

model Client {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  name          String
  email         String
  phone         String?
  address       String?
  companyName   String?
  notes         String?
  matters       Matter[]
  documents     Document[]
  trustAccounts TrustAccount[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId])
}

model Matter {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  clientId          String
  client            Client             @relation(fields: [clientId], references: [id])
  title             String
  matterNumber      String?
  practiceArea      String?
  status            MatterStatus       @default(ACTIVE)
  description       String?
  openedAt          DateTime           @default(now())
  closedAt          DateTime?
  documents         Document[]
  timeEntries       TimeEntry[]
  trustTransactions TrustTransaction[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([userId, matterNumber])
  @@index([userId])
  @@index([clientId])
  @@index([status])
}

model Document {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  matterId  String?
  matter    Matter?      @relation(fields: [matterId], references: [id])
  clientId  String?
  client    Client?      @relation(fields: [clientId], references: [id])
  title     String
  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String
  kind      DocumentKind @default(OTHER)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId])
  @@index([matterId])
}

model TimeEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  matterId    String
  matter      Matter   @relation(fields: [matterId], references: [id])
  description String
  minutes     Int
  rateInCents Int
  date        DateTime
  billable    Boolean  @default(true)
  invoiced    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([matterId])
  @@index([date])
}

model TrustAccount {
  id             String             @id @default(cuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id])
  clientId       String
  client         Client             @relation(fields: [clientId], references: [id])
  balanceInCents Int                @default(0)
  currency       String             @default("USD")
  transactions   TrustTransaction[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([userId, clientId])
}

model TrustTransaction {
  id             String               @id @default(cuid())
  trustAccountId String
  trustAccount   TrustAccount         @relation(fields: [trustAccountId], references: [id])
  type           TrustTransactionType
  amountInCents  Int
  description    String
  matterId       String?
  matter         Matter?              @relation(fields: [matterId], references: [id])
  createdAt      DateTime             @default(now())

  @@index([trustAccountId, createdAt])
}

// ============================================================
// MARKETPLACE — Stripe Connect escrow payments
// ============================================================

model MarketplacePayment {
  id                    String    @id @default(cuid())
  payerUserId           String?
  professionalUserId    String
  professional          User      @relation("ProfessionalPayments", fields: [professionalUserId], references: [id])
  stripePaymentIntentId String    @unique
  amountCents           Int
  applicationFeeCents   Int
  currency              String    @default("usd")
  status                String
  description           String?
  matterId              String?
  capturedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([professionalUserId])
  @@index([status])
}

// ============================================================
// MARCO REID VOICE — Whisper dictation
// ============================================================

model VoiceTranscript {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  text       String   @db.Text
  durationMs Int?
  language   String? // detected or specified language
  surface    String? // where the dictation happened: "dashboard", "matter", "email", etc.
  matterId   String? // optional link to matter
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ============================================================
// THE ORACLE — Brain, Memory, and Flywheel
// ============================================================

enum QueryDomain {
  LEGAL
  ACCOUNTING
  CROSS_DOMAIN
  IP
}

enum CitationStatus {
  VERIFIED
  UNVERIFIED
  NOT_FOUND
}

// Every query ever made — the memory
model OracleQuery {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  query          String // The raw question asked
  domain         QueryDomain // Legal, Accounting, Cross-domain, IP
  jurisdiction   String? // US, NZ, AU, UK, or specific state
  context        String? // Matter context, previous queries, etc.
  response       String // Marco's full response
  citations      OracleCitation[]
  feedback       OracleFeedback[]
  matterId       String? // Link to matter if query was in-context
  surface        String? // Where the query was made: document, email, cmd-k, etc.
  responseTimeMs Int? // How long the response took
  createdAt      DateTime         @default(now())

  @@index([userId])
  @@index([domain])
  @@index([createdAt])
  @@index([jurisdiction])
}

// Every citation returned — verified or not
model OracleCitation {
  id           String         @id @default(cuid())
  queryId      String
  query        OracleQuery    @relation(fields: [queryId], references: [id])
  title        String // Case name, statute title, IRS section
  citation     String // Formal citation string
  sourceUrl    String? // Direct link to authoritative source
  sourceDb     String? // CourtListener, IRS.gov, Cornell LII, USPTO, etc.
  status       CitationStatus // VERIFIED, UNVERIFIED, NOT_FOUND
  excerpt      String? // Relevant excerpt from the source
  jurisdiction String? // Jurisdiction of the citation
  dateDecided  String? // Date of case decision or ruling
  wasInserted  Boolean        @default(false) // Did the user insert this into a document?
  wasClicked   Boolean        @default(false) // Did the user click to view full text?
  createdAt    DateTime       @default(now())

  @@index([queryId])
  @@index([status])
  @@index([sourceDb])
}

// User feedback on results — the flywheel learning signal
model OracleFeedback {
  id        String      @id @default(cuid())
  queryId   String
  query     OracleQuery @relation(fields: [queryId], references: [id])
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  rating    Int // 1-5 star rating
  helpful   Boolean? // Was this result helpful?
  accurate  Boolean? // Was this result accurate?
  comment   String? // Free text feedback
  createdAt DateTime    @default(now())

  @@index([queryId])
  @@index([userId])
}

// ============================================================
// DATA SOURCES — what Marco knows about
// ============================================================

model DataSource {
  id          String      @id @default(cuid())
  name        String      @unique // CourtListener, IRS.gov, Cornell LII, etc.
  domain      QueryDomain // What domain this source covers
  baseUrl     String // API endpoint or base URL
  apiKey      String? // API key if required (encrypted in env)
  lastSynced  DateTime? // Last time we pulled data
  recordCount Int         @default(0) // How many records we have
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ============================================================
// FLYWHEEL ANALYTICS — the learning engine
// ============================================================

// Tracks what queries are most common — informs data priority
model QueryPattern {
  id          String      @id @default(cuid())
  pattern     String // Normalised query pattern
  domain      QueryDomain
  count       Int         @default(1) // How many times this pattern was queried
  avgRating   Float? // Average user rating for this pattern
  lastQueried DateTime    @default(now())
  createdAt   DateTime    @default(now())

  @@unique([pattern, domain])
  @@index([count(sort: Desc)])
}

// ============================================================
// COURTS — pilot requests from court procurement leads
// ============================================================

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  verifiedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model CourtPilotRequest {
  id           String   @id @default(cuid())
  name         String
  role         String
  court        String
  jurisdiction String
  email        String
  phone        String?
  products     String[]
  useCase      String   @db.Text
  status       String   @default("new")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([createdAt(sort: Desc)])
}

// ============================================================
// MARKETPLACE — citizens post matters, licensed pros accept them,
// every AI output passes through a SignoffRequest before release.
// Fee model respects ABA Model Rule 5.4 + NZ Lawyers and Conveyancers
// Act fee-splitting rules: flat lead fee + SaaS subscription, never a
// percentage of the pro's professional fee.
// ============================================================

enum ProfessionDomain {
  LAW
  ACCOUNTING
}

enum ProMatterStatus {
  DRAFT              // citizen still writing the intake
  AWAITING_PRO       // posted, waiting for a pro to accept
  ACCEPTED           // pro accepted, in progress
  AWAITING_SIGNOFF   // work drafted, pending final sign-off
  SIGNED_OFF         // released to citizen
  CLOSED
  CANCELLED
}

enum SignoffStatus {
  PENDING
  APPROVED
  REJECTED
  AMENDED
}

// Catalogue of practice areas. Seeded per jurisdiction so a NZ tenancy
// matter cannot accidentally route to a US-only professional.
model PracticeArea {
  id                    String                    @id @default(cuid())
  slug                  String                    @unique
  name                  String
  domain                ProfessionDomain
  jurisdiction          String                    // "NZ", "AU", "US", "UK", "CA"
  summary               String
  intakeCopy            String                    @db.Text
  leadFeeInCents        Int                       @default(0)
  currency              String                    @default("NZD")
  active                Boolean                   @default(true)
  priority              Int                       @default(0)
  // Per-practice-area acknowledgment — shown to citizens in the intake flow.
  // Versioned so we can prove what a given ProMatter's owner agreed to.
  ackVersion            String                    @default("2026-04-20")
  ackBullets            String[]
  professionals         ProfessionalPracticeArea[]
  proMatters            ProMatter[]
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@index([jurisdiction, domain])
  @@index([active, priority])
}

// A verified licensed professional. Linked 1:1 with a User row.
// verifiedAt is required before the pro can appear in citizen matching;
// piPolicyExpiresAt is checked on every matter assignment — expired PI
// insurance blocks acceptance.
model Professional {
  id                    String                    @id @default(cuid())
  userId                String                    @unique
  user                  User                      @relation("ProfessionalProfile", fields: [userId], references: [id])
  displayName           String
  bio                   String?                   @db.Text
  admissionJurisdiction String
  admissionNumber       String
  admissionYear         Int?
  professionalBody      String                    // "NZ Law Society", "CA ANZ", "NZICA", etc.
  piInsurerName         String?
  piPolicyNumber        String?
  piPolicyExpiresAt     DateTime?
  acceptingNewMatters   Boolean                   @default(true)
  verifiedAt            DateTime?
  verifiedBy            String?                   // admin User.id who verified
  practiceAreas         ProfessionalPracticeArea[]
  acceptedMatters       ProMatter[]               @relation("AcceptedBy")
  signoffs              SignoffRequest[]          @relation("SignedBy")
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@index([admissionJurisdiction])
  @@index([acceptingNewMatters, verifiedAt])
}

// Pro <-> PracticeArea M:N
model ProfessionalPracticeArea {
  professionalId  String
  professional    Professional  @relation(fields: [professionalId], references: [id])
  practiceAreaId  String
  practiceArea    PracticeArea  @relation(fields: [practiceAreaId], references: [id])
  assignedAt      DateTime      @default(now())

  @@id([professionalId, practiceAreaId])
  @@index([practiceAreaId])
}

// A citizen-posted matter. Lives through DRAFT → AWAITING_PRO → ACCEPTED
// → AWAITING_SIGNOFF → SIGNED_OFF. leadFeeInCents is snapshotted at post
// time so a later fee change doesn't retroactively alter the deal.
model ProMatter {
  id                      String          @id @default(cuid())
  citizenUserId           String
  citizen                 User            @relation("CitizenMatters", fields: [citizenUserId], references: [id])
  practiceAreaId          String
  practiceArea            PracticeArea    @relation(fields: [practiceAreaId], references: [id])
  jurisdiction            String
  summary                 String
  details                 String          @db.Text
  status                  ProMatterStatus @default(DRAFT)
  leadFeeInCents          Int
  consumerFeeInCents      Int?
  currency                String          @default("NZD")

  // Per-area acknowledgment snapshot — evidentiary record that this
  // specific citizen agreed to this specific version of the intake
  // acknowledgment for this specific practice area.
  ackVersion              String?
  ackAt                   DateTime?

  acceptedByProId         String?
  acceptedBy              Professional?   @relation("AcceptedBy", fields: [acceptedByProId], references: [id])
  acceptedAt              DateTime?
  postedAt                DateTime?
  closedAt                DateTime?

  signoffRequests         SignoffRequest[]

  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  @@index([status])
  @@index([practiceAreaId, status])
  @@index([citizenUserId])
  @@index([acceptedByProId])
}

// Every AI output destined for a consumer passes through here. The
// outputSha256 is the tamper-evidence hash — if the output or a
// derivative is altered after sign-off, the hash mismatch catches it.
// releasedAt gates when the consumer actually sees the work.
model SignoffRequest {
  id             String        @id @default(cuid())
  proMatterId    String
  proMatter      ProMatter     @relation(fields: [proMatterId], references: [id])
  kind           String        // "draft-letter", "tax-return", "advice-note", etc.
  aiOutput       String        @db.Text
  outputSha256   String
  rationale      String?       @db.Text
  citationsJson  String?       @db.Text  // serialized citation refs

  status         SignoffStatus @default(PENDING)
  reviewerId     String?
  reviewer       Professional? @relation("SignedBy", fields: [reviewerId], references: [id])
  reviewerNotes  String?       @db.Text
  amendedOutput  String?       @db.Text
  amendedSha256  String?

  requestedAt    DateTime      @default(now())
  reviewedAt     DateTime?
  releasedAt     DateTime?

  @@index([proMatterId])
  @@index([status])
  @@index([reviewerId])
  @@index([requestedAt])
}

// ============================================================
// GENERAL LEDGER
// ============================================================
//
// Marco Reid runs its own general ledger. We are not a plugin on top of
// somebody else's accounting product — we are the source of truth.
// Bank feeds arrive direct from neutral open-banking infrastructure
// (Akahu in NZ, Basiq in AU, Plaid in US, TrueLayer in UK), are
// deduplicated against `providerTxId`, suggested against the firm's own
// chart of accounts, and posted into double-entry journals once a human
// confirms. Every report (trial balance, P&L, balance sheet) is computed
// from POSTED `JournalLine` rows — never from running totals on accounts,
// which are derivable, not authoritative.

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  CONTRA_ASSET
  CONTRA_LIABILITY
}

enum AccountSubType {
  // Assets
  CASH
  BANK
  ACCOUNTS_RECEIVABLE
  INVENTORY
  FIXED_ASSET
  PREPAID
  OTHER_ASSET
  // Liabilities
  ACCOUNTS_PAYABLE
  TAX_PAYABLE
  LOAN_PAYABLE
  OTHER_LIABILITY
  // Equity
  OWNER_EQUITY
  RETAINED_EARNINGS
  // Revenue
  SERVICE_REVENUE
  PRODUCT_REVENUE
  OTHER_INCOME
  // Expense
  COST_OF_SALES
  OPERATING_EXPENSE
  PAYROLL_EXPENSE
  TAX_EXPENSE
  INTEREST_EXPENSE
  OTHER_EXPENSE
}

enum JournalStatus {
  DRAFT
  POSTED
  VOIDED
}

enum BankFeedProvider {
  AKAHU // NZ
  BASIQ // AU
  PLAID // US
  TRUELAYER // UK
}

enum BankFeedStatus {
  ACTIVE
  PAUSED
  ERROR
  REVOKED
}

enum BankTransactionStatus {
  UNCATEGORISED
  SUGGESTED
  CATEGORISED
  RECONCILED
  IGNORED
}

model ChartOfAccounts {
  id          String         @id @default(cuid())
  firmId      String
  code        String // e.g., "1000", "4000"
  name        String // e.g., "Cash on Hand"
  type        AccountType
  subType     AccountSubType
  parentId    String? // for sub-accounts
  isActive    Boolean        @default(true)
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  parent       ChartOfAccounts?  @relation("AccountTree", fields: [parentId], references: [id])
  children     ChartOfAccounts[] @relation("AccountTree")
  journalLines JournalLine[]

  @@unique([firmId, code])
  @@index([firmId, type])
}

model JournalEntry {
  id          String        @id @default(cuid())
  firmId      String
  entryNumber Int // sequential per firm
  entryDate   DateTime
  description String
  reference   String? // external reference (invoice #, bank tx id)
  status      JournalStatus @default(DRAFT)
  postedAt    DateTime?
  postedById  String?
  voidedAt    DateTime?
  voidReason  String?
  sourceType  String? // MANUAL | BANK_IMPORT | INVOICE | PAYROLL | RECURRING
  sourceRef   String? // id of the source record
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lines JournalLine[]

  @@unique([firmId, entryNumber])
  @@index([firmId, entryDate])
  @@index([status])
}

model JournalLine {
  id             String   @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal  @default(0) @db.Decimal(18, 2)
  credit         Decimal  @default(0) @db.Decimal(18, 2)
  description    String?
  createdAt      DateTime @default(now())

  journalEntry JournalEntry    @relation(fields: [journalEntryId], references: [id])
  account      ChartOfAccounts @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}

model BankConnection {
  id                   String           @id @default(cuid())
  firmId               String
  provider             BankFeedProvider
  providerAccountId    String // provider's connection identifier
  institutionName      String
  status               BankFeedStatus   @default(ACTIVE)
  lastSyncedAt         DateTime?
  encryptedAccessToken String?          @db.Text // sealed token; rotation handled later
  errorMessage         String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  bankAccounts BankAccount[]

  @@index([firmId, status])
}

model BankAccount {
  id                  String    @id @default(cuid())
  firmId              String
  bankConnectionId    String? // null for manually added
  ledgerAccountId     String? // FK to ChartOfAccounts when mapped
  providerAccountId   String? // provider-side account id
  name                String
  accountNumberMasked String // last-4 only
  accountType         String // CHECKING | SAVINGS | CREDIT_CARD | LOAN
  currency            String    @default("NZD")
  currentBalance      Decimal?  @db.Decimal(18, 2)
  availableBalance    Decimal?  @db.Decimal(18, 2)
  lastBalanceAt       DateTime?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  bankConnection BankConnection?   @relation(fields: [bankConnectionId], references: [id])
  transactions   BankTransaction[]

  @@index([firmId, isActive])
}

model BankTransaction {
  id                   String                @id @default(cuid())
  bankAccountId        String
  providerTxId         String // provider's transaction id, used for dedup
  amount               Decimal               @db.Decimal(18, 2)
  currency             String                @default("NZD")
  description          String
  merchantName         String?
  category             String? // raw category from provider
  occurredAt           DateTime
  importedAt           DateTime              @default(now())
  status               BankTransactionStatus @default(UNCATEGORISED)
  suggestedAccountId   String? // ChartOfAccounts id suggested by AI
  matchedJournalLineId String? // FK once reconciled
  notes                String?

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])

  @@unique([bankAccountId, providerTxId])
  @@index([bankAccountId, occurredAt])
  @@index([status])
}

model CategorisationRule {
  id           String   @id @default(cuid())
  firmId       String
  matchPattern String // regex or contains
  matchField   String // "DESCRIPTION" | "MERCHANT" | "CATEGORY"
  accountId    String // ChartOfAccounts to assign
  isActive     Boolean  @default(true)
  hits         Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([firmId, isActive])
}
