generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// AUTH
// ============================================================

enum Role {
  USER
  ADMIN
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  emailVerifiedAt DateTime?
  name          String?
  passwordHash  String
  role          Role             @default(USER)
  firmName      String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  queries          MarcoQuery[]
  feedback         MarcoFeedback[]
  clients          Client[]
  matters          Matter[]
  documents        Document[]
  timeEntries      TimeEntry[]
  trustAccounts    TrustAccount[]
  voiceTranscripts VoiceTranscript[]

  // Flywheel
  learningEvents     LearningEvent[]      @relation("LearningEventActor")
  firmHealthSnapshots FirmHealthSnapshot[] @relation("FirmHealthSnapshots")

  // Marketplace
  professionalProfile Professional? @relation("ProfessionalProfile")
  citizenMatters      ProMatter[]   @relation("CitizenMatters")

  // Stripe — subscriptions
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique
  stripePriceId         String?
  subscriptionStatus    String?
  subscriptionPeriodEnd DateTime?

  // Stripe Connect — marketplace
  stripeConnectAccountId String?              @unique
  connectOnboarded       Boolean              @default(false)
  marketplacePayments    MarketplacePayment[] @relation("ProfessionalPayments")

  // Onboarding
  onboardedAt   DateTime?
  jurisdiction  String?
  practiceArea  String?

  // Consent audit trail — evidentiary record for ToS + platform acknowledgment.
  // Versioned so we can tell who accepted which wording. IP + user-agent
  // captured at signup for the same reason. See lib/consent.ts for the current
  // versions and the acknowledgment text.
  tosVersion         String?
  tosAcceptedAt      DateTime?
  platformAckVersion String?
  platformAckAt      DateTime?
  signupIp           String?
  signupUserAgent    String?

  // Practice modules
  amlAssessments       AmlAssessment[]            @relation("AmlAssessments")
  suspiciousReports    SuspiciousActivityReport[] @relation("SARsCreated")
  cpdRecords           CpdRecord[]                @relation("CpdRecords")
  conveyancingMatters  ConveyancingMatter[]       @relation("ConveyancingMatters")
  willRecords          WillRecord[]               @relation("WillRecords")

  // Compliance ledgers — append-only, retention-bound, regulator-exportable.
  auditLogs            AuditLog[]                 @relation("AuditLogActor")
  communications       CommunicationRecord[]      @relation("CommunicationActor")
  regulatorFilings     RegulatorFiling[]          @relation("RegulatorFilingFiledBy")
  accessGrantsMade     AccessGrant[]              @relation("AccessGrantGrantor")
  accessGrantsHeld     AccessGrant[]              @relation("AccessGrantSubject")
  privacyBreachReports PrivacyBreachIncident[]    @relation("PrivacyBreachReporter")
  complaintsLogged     ComplaintRecord[]          @relation("ComplaintLoggedBy")
  legalHoldsRequested  LegalHold[]                @relation("LegalHoldRequester")

  // Firm membership — the multi-tenancy spine. A user belongs to one or more
  // firms via FirmMembership; each membership carries credentials, bar numbers,
  // and sign-off authority. See models below.
  firmMemberships      FirmMembership[]           @relation("FirmMembershipUser")
}

// ============================================================
// PRACTICE FOUNDATION — Clients, Matters, Documents, Billing
// ============================================================

enum MatterStatus {
  ACTIVE
  ON_HOLD
  CLOSED
}

enum DocumentKind {
  CONTRACT
  LETTER
  COURT_FILING
  EVIDENCE
  INVOICE
  RECEIPT
  ENGAGEMENT_LETTER
  WILL
  OTHER
}

enum TrustTransactionType {
  DEPOSIT
  WITHDRAWAL
  FEE_DRAW
}

model Client {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  name          String
  email         String
  phone         String?
  address       String?
  companyName   String?
  notes         String?
  matters       Matter[]
  documents     Document[]
  trustAccounts TrustAccount[]
  amlAssessments     AmlAssessment[]
  suspiciousReports  SuspiciousActivityReport[] @relation("SARsByClient")
  willsAsTestator    WillRecord[]               @relation("WillsAsTestator")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId])
}

model Matter {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  clientId          String
  client            Client             @relation(fields: [clientId], references: [id])
  title             String
  matterNumber      String?
  practiceArea      String?
  status            MatterStatus       @default(ACTIVE)
  description       String?
  openedAt          DateTime           @default(now())
  closedAt          DateTime?
  documents         Document[]
  timeEntries       TimeEntry[]
  trustTransactions TrustTransaction[]
  conveyancing      ConveyancingMatter?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([userId, matterNumber])
  @@index([userId])
  @@index([clientId])
  @@index([status])
}

model Document {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id])
  matterId  String?
  matter    Matter?           @relation(fields: [matterId], references: [id])
  clientId  String?
  client    Client?           @relation(fields: [clientId], references: [id])
  title     String
  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String
  kind      DocumentKind      @default(OTHER)
  versions  DocumentVersion[]
  createdAt DateTime          @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId])
  @@index([matterId])
}

model TimeEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  matterId    String
  matter      Matter   @relation(fields: [matterId], references: [id])
  description String
  minutes     Int
  rateInCents Int
  date        DateTime
  billable    Boolean  @default(true)
  invoiced    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([matterId])
  @@index([date])
}

model TrustAccount {
  id             String             @id @default(cuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id])
  clientId       String
  client         Client             @relation(fields: [clientId], references: [id])
  balanceInCents Int                @default(0)
  currency       String             @default("USD")
  transactions   TrustTransaction[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([userId, clientId])
}

model TrustTransaction {
  id             String               @id @default(cuid())
  trustAccountId String
  trustAccount   TrustAccount         @relation(fields: [trustAccountId], references: [id])
  type           TrustTransactionType
  amountInCents  Int
  description    String
  matterId       String?
  matter         Matter?              @relation(fields: [matterId], references: [id])
  createdAt      DateTime             @default(now())

  @@index([trustAccountId, createdAt])
}

// ============================================================
// MARKETPLACE — Stripe Connect escrow payments
// ============================================================

model MarketplacePayment {
  id                    String    @id @default(cuid())
  payerUserId           String?
  professionalUserId    String
  professional          User      @relation("ProfessionalPayments", fields: [professionalUserId], references: [id])
  stripePaymentIntentId String    @unique
  amountCents           Int
  applicationFeeCents   Int
  currency              String    @default("usd")
  status                String
  description           String?
  matterId              String?
  capturedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([professionalUserId])
  @@index([status])
}

// ============================================================
// MARCO REID VOICE — Whisper dictation
// ============================================================

model VoiceTranscript {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  text       String   @db.Text
  durationMs Int?
  language   String? // detected or specified language
  surface    String? // where the dictation happened: "dashboard", "matter", "email", etc.
  matterId   String? // optional link to matter
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ============================================================
// MARCO — Brain, Memory, and Flywheel.
// (DB table names kept as Oracle* via @@map so existing data and any
// running migrations stay valid; the TypeScript surface is fully
// renamed.)
// ============================================================

enum QueryDomain {
  LEGAL
  ACCOUNTING
  CROSS_DOMAIN
  IP
}

enum CitationStatus {
  VERIFIED
  UNVERIFIED
  NOT_FOUND
}

// Every query ever made — the memory
model MarcoQuery {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  query          String // The raw question asked
  domain         QueryDomain // Legal, Accounting, Cross-domain, IP
  jurisdiction   String? // US, NZ, AU, UK, or specific state
  context        String? // Matter context, previous queries, etc.
  response       String // Marco's full response
  citations      MarcoCitation[]
  feedback       MarcoFeedback[]
  matterId       String? // Link to matter if query was in-context
  surface        String? // Where the query was made: document, email, cmd-k, etc.
  responseTimeMs Int? // How long the response took
  createdAt      DateTime        @default(now())

  @@index([userId])
  @@index([domain])
  @@index([createdAt])
  @@index([jurisdiction])
  @@map("OracleQuery")
}

// Every citation returned — verified or not
model MarcoCitation {
  id           String         @id @default(cuid())
  queryId      String
  query        MarcoQuery     @relation(fields: [queryId], references: [id])
  title        String // Case name, statute title, IRS section
  citation     String // Formal citation string
  sourceUrl    String? // Direct link to authoritative source
  sourceDb     String? // CourtListener, IRS.gov, Cornell LII, USPTO, etc.
  status       CitationStatus // VERIFIED, UNVERIFIED, NOT_FOUND
  excerpt      String? // Relevant excerpt from the source
  jurisdiction String? // Jurisdiction of the citation
  dateDecided  String? // Date of case decision or ruling
  wasInserted  Boolean        @default(false) // Did the user insert this into a document?
  wasClicked   Boolean        @default(false) // Did the user click to view full text?
  createdAt    DateTime       @default(now())

  @@index([queryId])
  @@index([status])
  @@index([sourceDb])
  @@map("OracleCitation")
}

// User feedback on results — the flywheel learning signal
model MarcoFeedback {
  id        String     @id @default(cuid())
  queryId   String
  query     MarcoQuery @relation(fields: [queryId], references: [id])
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  rating    Int // 1-5 star rating
  helpful   Boolean? // Was this result helpful?
  accurate  Boolean? // Was this result accurate?
  comment   String? // Free text feedback
  createdAt DateTime   @default(now())

  @@index([queryId])
  @@index([userId])
  @@map("OracleFeedback")
}

// ============================================================
// DATA SOURCES — what Marco knows about
// ============================================================

model DataSource {
  id          String      @id @default(cuid())
  name        String      @unique // CourtListener, IRS.gov, Cornell LII, etc.
  domain      QueryDomain // What domain this source covers
  baseUrl     String // API endpoint or base URL
  apiKey      String? // API key if required (encrypted in env)
  lastSynced  DateTime? // Last time we pulled data
  recordCount Int         @default(0) // How many records we have
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ============================================================
// FLYWHEEL ANALYTICS — the learning engine
// ============================================================

// Tracks what queries are most common — informs data priority
model QueryPattern {
  id          String      @id @default(cuid())
  pattern     String // Normalised query pattern
  domain      QueryDomain
  count       Int         @default(1) // How many times this pattern was queried
  avgRating   Float? // Average user rating for this pattern
  lastQueried DateTime    @default(now())
  createdAt   DateTime    @default(now())

  @@unique([pattern, domain])
  @@index([count(sort: Desc)])
}

// ============================================================
// COURTS — pilot requests from court procurement leads
// ============================================================

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  verifiedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model CourtPilotRequest {
  id           String   @id @default(cuid())
  name         String
  role         String
  court        String
  jurisdiction String
  email        String
  phone        String?
  products     String[]
  useCase      String   @db.Text
  status       String   @default("new")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([createdAt(sort: Desc)])
}

// ============================================================
// MARKETPLACE — citizens post matters, licensed pros accept them,
// every AI output passes through a SignoffRequest before release.
// Fee model respects ABA Model Rule 5.4 + NZ Lawyers and Conveyancers
// Act fee-splitting rules: flat lead fee + SaaS subscription, never a
// percentage of the pro's professional fee.
// ============================================================

enum ProfessionDomain {
  LAW
  ACCOUNTING
}

enum ProMatterStatus {
  DRAFT              // citizen still writing the intake
  AWAITING_PRO       // posted, waiting for a pro to accept
  ACCEPTED           // pro accepted, in progress
  AWAITING_SIGNOFF   // work drafted, pending final sign-off
  SIGNED_OFF         // released to citizen
  CLOSED
  CANCELLED
}

enum SignoffStatus {
  PENDING
  APPROVED
  REJECTED
  AMENDED
}

// Catalogue of practice areas. Seeded per jurisdiction so a NZ tenancy
// matter cannot accidentally route to a US-only professional.
model PracticeArea {
  id                    String                    @id @default(cuid())
  slug                  String                    @unique
  name                  String
  domain                ProfessionDomain
  jurisdiction          String                    // "NZ", "AU", "US", "UK", "CA"
  summary               String
  intakeCopy            String                    @db.Text
  leadFeeInCents        Int                       @default(0)
  currency              String                    @default("NZD")
  active                Boolean                   @default(true)
  priority              Int                       @default(0)
  // Per-practice-area acknowledgment — shown to citizens in the intake flow.
  // Versioned so we can prove what a given ProMatter's owner agreed to.
  ackVersion            String                    @default("2026-04-20")
  ackBullets            String[]
  professionals         ProfessionalPracticeArea[]
  proMatters            ProMatter[]
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@index([jurisdiction, domain])
  @@index([active, priority])
}

// A verified licensed professional. Linked 1:1 with a User row.
// verifiedAt is required before the pro can appear in citizen matching;
// piPolicyExpiresAt is checked on every matter assignment — expired PI
// insurance blocks acceptance.
model Professional {
  id                    String                    @id @default(cuid())
  userId                String                    @unique
  user                  User                      @relation("ProfessionalProfile", fields: [userId], references: [id])
  displayName           String
  bio                   String?                   @db.Text
  admissionJurisdiction String
  admissionNumber       String
  admissionYear         Int?
  professionalBody      String                    // "NZ Law Society", "CA ANZ", "NZICA", etc.
  piInsurerName         String?
  piPolicyNumber        String?
  piPolicyExpiresAt     DateTime?
  acceptingNewMatters   Boolean                   @default(true)
  verifiedAt            DateTime?
  verifiedBy            String?                   // admin User.id who verified
  practiceAreas         ProfessionalPracticeArea[]
  acceptedMatters       ProMatter[]               @relation("AcceptedBy")
  signoffs              SignoffRequest[]          @relation("SignedBy")
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@index([admissionJurisdiction])
  @@index([acceptingNewMatters, verifiedAt])
}

// Pro <-> PracticeArea M:N
model ProfessionalPracticeArea {
  professionalId  String
  professional    Professional  @relation(fields: [professionalId], references: [id])
  practiceAreaId  String
  practiceArea    PracticeArea  @relation(fields: [practiceAreaId], references: [id])
  assignedAt      DateTime      @default(now())

  @@id([professionalId, practiceAreaId])
  @@index([practiceAreaId])
}

// A citizen-posted matter. Lives through DRAFT → AWAITING_PRO → ACCEPTED
// → AWAITING_SIGNOFF → SIGNED_OFF. leadFeeInCents is snapshotted at post
// time so a later fee change doesn't retroactively alter the deal.
model ProMatter {
  id                      String          @id @default(cuid())
  citizenUserId           String
  citizen                 User            @relation("CitizenMatters", fields: [citizenUserId], references: [id])
  practiceAreaId          String
  practiceArea            PracticeArea    @relation(fields: [practiceAreaId], references: [id])
  jurisdiction            String
  summary                 String
  details                 String          @db.Text
  status                  ProMatterStatus @default(DRAFT)
  leadFeeInCents          Int
  consumerFeeInCents      Int?
  currency                String          @default("NZD")

  // Per-area acknowledgment snapshot — evidentiary record that this
  // specific citizen agreed to this specific version of the intake
  // acknowledgment for this specific practice area.
  ackVersion              String?
  ackAt                   DateTime?

  acceptedByProId         String?
  acceptedBy              Professional?   @relation("AcceptedBy", fields: [acceptedByProId], references: [id])
  acceptedAt              DateTime?
  postedAt                DateTime?
  closedAt                DateTime?

  signoffRequests         SignoffRequest[]

  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  @@index([status])
  @@index([practiceAreaId, status])
  @@index([citizenUserId])
  @@index([acceptedByProId])
}

// Every AI output destined for a consumer passes through here. The
// outputSha256 is the tamper-evidence hash — if the output or a
// derivative is altered after sign-off, the hash mismatch catches it.
// releasedAt gates when the consumer actually sees the work.
model SignoffRequest {
  id             String        @id @default(cuid())
  proMatterId    String
  proMatter      ProMatter     @relation(fields: [proMatterId], references: [id])
  kind           String        // "draft-letter", "tax-return", "advice-note", etc.
  aiOutput       String        @db.Text
  outputSha256   String
  rationale      String?       @db.Text
  citationsJson  String?       @db.Text  // serialized citation refs

  status         SignoffStatus @default(PENDING)
  reviewerId     String?
  reviewer       Professional? @relation("SignedBy", fields: [reviewerId], references: [id])
  reviewerNotes  String?       @db.Text
  amendedOutput  String?       @db.Text
  amendedSha256  String?

  requestedAt    DateTime      @default(now())
  reviewedAt     DateTime?
  releasedAt     DateTime?

  @@index([proMatterId])
  @@index([status])
  @@index([reviewerId])
  @@index([requestedAt])
}

// ============================================================
// PLATFORM FLYWHEEL — central learning ledger.
//
// Every meaningful signal in the platform writes a LearningEvent here:
// - USAGE     : a feature was used / abandoned (telemetry)
// - AI_QUERY  : a Marco query happened (links MarcoQuery)
// - AI_FEEDBACK : a Marco answer was rated (links MarcoFeedback)
// - WORKFLOW  : a matter sign-off cycle progressed (links SignoffRequest)
// - REGULATORY: a statute / tax rule change was detected, possibly
//               flagging open matters (links RegulatoryUpdate)
//
// The ledger is read in two directions:
//   - per-firm dashboards roll it up into FirmHealthSnapshot
//   - we (the platform) read it for build-queue prioritisation
// ============================================================

enum LearningEventKind {
  USAGE
  AI_QUERY
  AI_FEEDBACK
  WORKFLOW
  REGULATORY
}

enum LearningEventSeverity {
  INFO
  POSITIVE   // Good outcome (fast cycle, high rating, correct flag)
  NEGATIVE   // Bad outcome (failed answer, missed deadline, NOT_FOUND)
  CRITICAL   // Hard blocker (sign-off rejected, regulatory miss)
}

model LearningEvent {
  id                  String                @id @default(cuid())
  kind                LearningEventKind
  severity            LearningEventSeverity @default(INFO)
  userId              String?
  user                User?                 @relation("LearningEventActor", fields: [userId], references: [id])

  // Context tags — none are mandatory but each makes future querying easier.
  surface             String?               // "marco-chat", "voice", "billing", "trust", etc.
  practiceArea        String?               // matches PracticeArea.slug or generic tag
  jurisdiction        String?               // NZ / AU / US / UK / CA

  // Pointers to source records — typically zero or one is non-null.
  marcoQueryId        String?
  marcoFeedbackId     String?
  signoffRequestId    String?
  proMatterId         String?
  voiceTranscriptId   String?
  regulatoryUpdateId  String?
  regulatoryUpdate    RegulatoryUpdate?     @relation(fields: [regulatoryUpdateId], references: [id])

  payload             Json?                 // event-specific structured data
  scoreDelta          Float?                // contribution to firm-health / AI-quality scoring
  createdAt           DateTime              @default(now())

  @@index([kind, createdAt])
  @@index([userId, createdAt])
  @@index([severity, createdAt])
  @@index([practiceArea, jurisdiction])
  @@index([surface])
}

// Regulatory radar. Every detected change of consequence — a statute
// amendment, an IRD/IRS notice, a CA ANZ practice note, a court
// decision that flips precedent — is recorded here. The matters
// pipeline matches open matters against `practiceAreas` and the
// matching pro / firm gets a flag in their dashboard.
model RegulatoryUpdate {
  id              String          @id @default(cuid())
  jurisdiction    String          // "NZ", "AU", "UK", "EU", "US", "CA"
  regime          String          // "Privacy Act 2020", "AML/CFT Act 2009", "Income Tax Act 2007", etc.
  citation        String          // Section, regulation number, case ref
  title           String
  summary         String          @db.Text
  effectiveAt     DateTime?
  sourceUrl       String?
  practiceAreas   String[]        // slug tags — matches against open ProMatter rows
  severity        LearningEventSeverity @default(INFO)
  detectedAt      DateTime        @default(now())
  events          LearningEvent[]

  @@index([jurisdiction, regime])
  @@index([detectedAt(sort: Desc)])
  @@index([severity, detectedAt])
}

// Nightly per-firm rollup of the LearningEvent ledger. Read by the
// firm's dashboard so the partner sees their own flywheel turn.
model FirmHealthSnapshot {
  id                       String   @id @default(cuid())
  userId                   String
  user                     User     @relation("FirmHealthSnapshots", fields: [userId], references: [id])
  asOf                     DateTime

  weeklyActiveFeatures     Int      @default(0)
  marcoQueriesThisWeek     Int      @default(0)
  marcoAvgRating           Float?
  marcoUnverifiedRate      Float?           // 0..1 — fraction of citations Unverified

  signoffsCompletedThisWeek Int     @default(0)
  signoffAvgCycleHours     Float?
  signoffRejectionRate     Float?            // 0..1

  cpdHoursLogged           Float?
  amlAssessmentsCurrent    Int      @default(0)
  trustReconciliationOk    Boolean  @default(true)
  regulatoryFlagsOpen      Int      @default(0)

  createdAt                DateTime @default(now())

  @@unique([userId, asOf])
  @@index([asOf])
}

// ============================================================
// AML / CFT — Anti-Money-Laundering / Countering Financing of
// Terrorism. NZ AML/CFT Act 2009 (and the AU AML/CTF Act 2006,
// US BSA, UK MLR 2017) require lawyers and accountants over the
// threshold to: identify clients (CDD), risk-rate them, monitor
// activity, file SARs / STRs.
// ============================================================

enum CddLevel {
  SIMPLIFIED
  STANDARD
  ENHANCED
}

enum AmlRiskRating {
  LOW
  MEDIUM
  HIGH
}

enum SarStatus {
  DRAFT
  SUBMITTED
  ACKNOWLEDGED
}

model AmlAssessment {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation("AmlAssessments", fields: [userId], references: [id])
  clientId          String?
  client            Client?       @relation(fields: [clientId], references: [id])

  jurisdiction      String        @default("NZ")
  cddLevel          CddLevel      @default(STANDARD)
  riskRating        AmlRiskRating @default(LOW)
  riskFactors       String[]      // PEP, high-risk-jurisdiction, cash-intensive, complex-structure, etc.

  identityVerified  Boolean       @default(false)
  identityDocs      Json?         // structured doc list
  beneficialOwner   Json?         // structured BO disclosure
  sourceOfFunds     String?
  sourceOfWealth    String?
  pepStatus         Boolean       @default(false)
  sanctionsHit      Boolean       @default(false)

  reviewedAt        DateTime?
  reviewedBy        String?       // User.id of reviewer
  nextReviewAt      DateTime?

  notes             String?       @db.Text

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([userId, riskRating])
  @@index([clientId])
  @@index([nextReviewAt])
  @@index([jurisdiction])
}

model SuspiciousActivityReport {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation("SARsCreated", fields: [userId], references: [id])
  clientId        String?
  client          Client?    @relation("SARsByClient", fields: [clientId], references: [id])
  matterId        String?

  jurisdiction    String     @default("NZ")
  reportType      String     // "SAR", "STR", "PRESCRIBED" depending on regime
  reportedTo      String     // "FIU" (NZ), "AUSTRAC" (AU), "FinCEN" (US), "NCA" (UK)

  narrative       String     @db.Text
  amountInCents   Int?
