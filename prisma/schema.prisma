  irdNumberNz          String?
  abnAu                String?
  acnAu                String?
  companyNumberUk      String?
  companyNumberNz      String?
  // Filings linked
  certificateUrl       String?
  certificateHash      String?
  // Bank account partner (Mercury, Wise, Brex, etc.)
  bankPartnerName      String?
  bankAccountRef       String?
  // Sign-off + filing references
  signoffRequestId     String?
  regulatorFilingId    String?
  notes                String?               @db.Text
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([firmId])
  @@index([founderUserId])
  @@index([status])
  @@index([formationType])
}
