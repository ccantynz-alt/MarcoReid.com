# Neon PostgreSQL (get these from your Neon project dashboard)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Admin seed (used by prisma/seed.ts)
ADMIN_EMAIL="admin@marcoreid.com"
ADMIN_PASSWORD="changeme123"

# Anthropic Claude API (Marco's brain)
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI Whisper — for Marco Reid Voice dictation
OPENAI_API_KEY="sk-..."

# Legal data sources
COURTLISTENER_API_KEY="your-courtlistener-api-key"
GOVINFO_API_KEY="your-govinfo-api-key"

# Stripe — get keys from dashboard.stripe.com
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_LEGAL_STARTER="price_..."
STRIPE_PRICE_LEGAL_PROFESSIONAL="price_..."
STRIPE_PRICE_LEGAL_FIRM="price_..."
STRIPE_PRICE_ACCOUNTING_STARTER="price_..."
STRIPE_PRICE_ACCOUNTING_PROFESSIONAL="price_..."
STRIPE_PRICE_ACCOUNTING_FIRM="price_..."
STRIPE_PRICE_MARCO_CROSSDOMAIN="price_..."
STRIPE_PRICE_MARCO_ENTERPRISE="price_..."
# Stripe Connect (marketplace)
STRIPE_CONNECT_CLIENT_ID="ca_..."

# Family network — sibling product /api/platform-status URLs.
# The admin sibling-products widget polls these every 30s with a 3s
# timeout to render unified family health cards. Defaults are baked
# into the widget; override here per-environment if needed.
NEXT_PUBLIC_CRONTECH_STATUS_URL="https://crontech.ai/api/platform-status"
NEXT_PUBLIC_GLUECRON_STATUS_URL="https://gluecron.com/api/platform-status"
NEXT_PUBLIC_GATETEST_STATUS_URL="https://gatetest.io/api/platform-status"
NEXT_PUBLIC_ALECRAE_STATUS_URL="https://alecrae.com/api/platform-status"

# Optional region tag — surfaces in /api/platform-status as the region
# field. Defaults to "auckland" if unset.
MARCO_REGION="auckland"
